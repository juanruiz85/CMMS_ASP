<%
' =============================================================================
' CMMS - Sistema de Internacionalización (i18n)
' Función T(key) para obtener strings en el idioma del usuario (ES/EN)
' =============================================================================

Function T(key)
    Dim lang
    If Session("user_lang") <> "" Then
        lang = LCase(Session("user_lang"))
    ElseIf Request.Cookies("cmms_lang") <> "" Then
        lang = LCase(Request.Cookies("cmms_lang"))
    Else
        lang = "es"
    End If

    Select Case lang
        Case "en"
            T = GetStringEN(key)
        Case Else
            T = GetStringES(key)
    End Select
End Function

