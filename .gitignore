```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.class
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build directories
dist/
build/
target/
.coverage
coverage/
htmlcov/

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# OS specific
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
julia-*/
zig*/
```